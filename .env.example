PORT=4000
NODE_ENV=development

# GitHub signs each webhook with HMAC-SHA256 using this secret.
# Generate a strong one with:  openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=replace_me_with_a_strong_random_string

# Comma-separated branch allow-list. Globs supported: "main,develop,release/*"
# Leave empty (or omit) to build every branch.
ALLOWED_BRANCHES=

# Dashboard / API / socket authentication. Set BOTH or leave BOTH empty.
# When empty the dashboard is open (dev only — server refuses to start in
# any non-development NODE_ENV if these are unset).
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# Demo mode for public portfolio deployment.
# When true: seeds mock builds on boot, disables auth, exposes
# POST /api/demo/build for one-click demo runs. Do not enable in production.
DEMO_MODE=false
